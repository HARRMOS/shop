generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  FEMME
  HOMME
  UNISEXE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  gender      Gender?
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  compareAt   Float?
  image       String
  images      String[]
  sizes       String[]
  colors      String[]
  gender      Gender
  featured    Boolean  @default(false)
  inStock     Boolean  @default(true)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id             String          @id @default(cuid())
  orderNumber    String          @unique
  status         OrderStatus     @default(PENDING)
  email          String
  firstName      String
  lastName       String
  phone          String
  address        String
  city           String
  postalCode     String
  country        String          @default("France")
  items          Json
  subtotal       Float
  shipping       Float           @default(0)
  total          Float
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  refundRequests RefundRequest[]

  @@index([email])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model CustomerProfile {
  id         String   @id @default(cuid())
  email      String   @unique
  firstName  String?
  lastName   String?
  phone      String?
  address    String?
  city       String?
  postalCode String?
  country    String   @default("France")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LoginToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model RefundRequest {
  id        String       @id @default(cuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  email     String
  reason    String
  status    RefundStatus @default(PENDING)
  adminNote String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([email])
  @@index([orderId])
}
