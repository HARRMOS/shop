# ─── Domaine ───
SHOP_DOMAIN=shop.ton-domaine.fr
NEXT_PUBLIC_SITE_URL=https://shop.ton-domaine.fr
NEXT_PUBLIC_SITE_NAME="Noor Collection"

# ─── PostgreSQL ───
POSTGRES_CONTAINER=noor-postgres
POSTGRES_ADMIN_USER=admin
POSTGRES_ADMIN_DB=haros
POSTGRES_USER=noor
POSTGRES_PASSWORD=changez_moi_mot_de_passe_fort
# Nom de la base — change-le ici, puis recrée-la sur le VPS (voir DEPLOY-OVH.md)
POSTGRES_DB=noor_shop

# Réseau Docker où tourne Postgres (voir: docker inspect TON_CONTENEUR)
POSTGRES_NETWORK=postgres

# ─── Traefik ───
TRAEFIK_NETWORK=traefik
TRAEFIK_CERT_RESOLVER=letsencrypt

# ─── App ───
AUTH_SECRET=changez_moi_une_longue_chaine_aleatoire
ADMIN_PASSWORD=changez_moi_admin
DEMO_MODE=false

# ─── Emails ───
# Tu peux utiliser une adresse PERSO (Gmail, Outlook, etc.)
SHOP_EMAIL=ton.email@gmail.com

# ── Option A : Gmail perso ──
# 1. Active la validation en 2 étapes sur ton compte Google
# 2. Crée un "Mot de passe d'application" : https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=ton.email@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM="Noor Collection <ton.email@gmail.com>"
# SMTP_SECURE=false

# ── Option B : Outlook / Hotmail perso ──
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=ton.email@outlook.com
# SMTP_PASS=ton_mot_de_passe
# SMTP_FROM="Noor Collection <ton.email@outlook.com>"
# SMTP_SECURE=false

# ── Option C : Email OVH pro ──
# SMTP_HOST=ssl0.ovh.net
# SMTP_PORT=587
# SMTP_USER=contact@ton-domaine.fr
# SMTP_PASS=mot_de_passe_email
# SMTP_FROM="Noor Collection <contact@ton-domaine.fr>"
# SMTP_SECURE=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ton.email@gmail.com
SMTP_PASS=mot_de_passe_application_gmail
SMTP_FROM="Noor Collection <ton.email@gmail.com>"
SMTP_SECURE=false
