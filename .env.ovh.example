# ─── Domaine ───
SHOP_DOMAIN=shop.ton-domaine.fr
NEXT_PUBLIC_SITE_URL=https://shop.ton-domaine.fr
NEXT_PUBLIC_SITE_NAME="Noor Collection"

# ─── PostgreSQL ───
POSTGRES_CONTAINER=noor-postgres
POSTGRES_ADMIN_USER=admin
POSTGRES_ADMIN_DB=haros
POSTGRES_USER=noor
POSTGRES_PASSWORD=changez_moi_mot_de_passe_fort
# Nom de la base — change-le ici, puis recrée-la sur le VPS (voir DEPLOY-OVH.md)
POSTGRES_DB=noor_shop

# Réseau Docker où tourne Postgres (voir: docker inspect TON_CONTENEUR)
POSTGRES_NETWORK=postgres

# ─── Traefik ───
TRAEFIK_NETWORK=traefik
TRAEFIK_CERT_RESOLVER=letsencrypt

# ─── App ───
AUTH_SECRET=changez_moi_une_longue_chaine_aleatoire
DEMO_MODE=false
