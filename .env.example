# ─── Local (PostgreSQL Homebrew) ───
DATABASE_URL="postgresql://noor:noor_secret@localhost:5432/noor_collection?schema=public"

# ─── Vercel (démo client — pas besoin de DATABASE_URL) ───
# Laisse DATABASE_URL vide sur Vercel → mode démo automatique
# NEXT_PUBLIC_SITE_URL sera ton URL Vercel, ex: https://shop-xxx.vercel.app

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Noor Collection"
AUTH_SECRET="dev-secret-local-only"

# Forcer le mode démo (optionnel)
# DEMO_MODE=true
