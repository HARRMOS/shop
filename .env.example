# Base de données — local sans Docker (Homebrew)
DATABASE_URL="postgresql://noor:noor_secret@localhost:5432/noor_collection?schema=public"

# Base de données — Docker / VPS OVH
# DATABASE_URL="postgresql://noor:noor_secret@postgres:5432/noor_collection?schema=public"

# URL publique du site
NEXT_PUBLIC_SITE_URL="https://votre-domaine.fr"
NEXT_PUBLIC_SITE_NAME="Noor Collection"

# Secret pour les sessions (générer avec: openssl rand -base64 32)
AUTH_SECRET="changez-moi-en-production"
